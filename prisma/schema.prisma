generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  BROKER
  TENANT
}

enum DocumentStatus {
  MISSING
  REQUESTED
  AVAILABLE
  SHARED
  NOT_RELEVANT
}

enum DocumentScope {
  PROPERTY
  UNIT
  TENANT
  CONTRACT
}

enum AuditAction {
  LOGIN
  FILE_UPLOADED
  FILE_VIEWED
  FILE_DOWNLOADED
  PERMISSION_CHANGED
  CONTRACT_GENERATED
  PROPERTY_CHANGED
  USER_INVITED
  BACKUP_EXPORTED
  BACKUP_IMPORTED
}

model PortalInstance {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  users       User[]
  properties  Property[]
  documents   Document[]
  categories  DocumentCategory[]
  templates   ContractTemplate[]
  auditLogs   AuditLog[]
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  username     String?
  portalInstanceId String?
  platformAdmin Boolean        @default(false)
  name         String?
  contactPerson String?
  contactAddress String?
  contactPhone String?
  contactEmail String?
  ownerBankName String?
  ownerIban    String?
  ownerTaxId   String?
  ownerNotes   String?
  passwordHash String
  role         Role            @default(TENANT)
  active       Boolean         @default(true)
  inviteToken  String?         @unique
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  documents    Document[]      @relation("UploadedDocuments")
  permissions  AccessPermission[]
  brokerLinks  BrokerRequest[]
  brokerValuations BrokerValuation[]
  tenantProfile TenantProfile?
  auditLogs    AuditLog[]
  portalInstance PortalInstance? @relation(fields: [portalInstanceId], references: [id], onDelete: Cascade)
}

model Property {
  id                    String          @id @default(cuid())
  portalInstanceId      String?
  name                  String
  address               String
  street                String?
  houseNumber           String?
  postalCode            String?
  city                  String?
  country               String?         @default("Deutschland")
  latitude              Float?
  longitude             Float?
  objectType            String?
  constructionYear      Int?
  livingArea            Decimal?        @db.Decimal(12, 2)
  usableArea            Decimal?        @db.Decimal(12, 2)
  plotArea              Decimal?        @db.Decimal(12, 2)
  rooms                 Decimal?        @db.Decimal(6, 2)
  unitCount             Int             @default(0)
  floor                 String?
  parkingSpaces         Int?
  energyCertificate     String?
  heatingType           String?
  condition             String?
  modernizations        String?
  rentalStatus          String?
  expectedPurchasePrice Decimal?        @db.Decimal(14, 2)
  outstandingLoan       Decimal?        @db.Decimal(14, 2)
  internalNotes         String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  units                 Unit[]
  documents             Document[]
  brokerRequests        BrokerRequest[]
  brokerValuations      BrokerValuation[]
  portalInstance        PortalInstance? @relation(fields: [portalInstanceId], references: [id], onDelete: Cascade)
}

model Unit {
  id          String          @id @default(cuid())
  propertyId  String
  unitNumber  String
  floor       String?
  rooms       Decimal?        @db.Decimal(6, 2)
  livingArea  Decimal?        @db.Decimal(12, 2)
  rentAmount  Decimal?        @db.Decimal(12, 2)
  garageRent  Decimal?        @db.Decimal(12, 2)
  serviceCharges Decimal?     @db.Decimal(12, 2)
  warmRent    Decimal?        @db.Decimal(12, 2)
  status      String?
  isSharedHousing Boolean     @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  property    Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  documents   Document[]
  tenants     TenantProfile[]
  contracts   LeaseContract[]
}

model DocumentCategory {
  id          String       @id @default(cuid())
  portalInstanceId String?
  group       String
  name        String
  description String?
  visibleToBroker Boolean  @default(true)
  visibleToTenant Boolean  @default(false)
  createdAt   DateTime     @default(now())
  documents   Document[]
  portalInstance PortalInstance? @relation(fields: [portalInstanceId], references: [id], onDelete: Cascade)

  @@unique([portalInstanceId, name])
}

model Document {
  id              String          @id @default(cuid())
  portalInstanceId String?
  title           String
  filename        String
  mimeType        String
  size            Int
  storagePath     String
  status          DocumentStatus  @default(AVAILABLE)
  scope           DocumentScope   @default(PROPERTY)
  propertyId      String?
  unitId          String?
  categoryId      String?
  uploadedById    String
  isPropertyImage Boolean         @default(false)
  isPrimaryImage  Boolean         @default(false)
  summary         String?
  tags            String[]        @default([])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  property        Property?       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit            Unit?           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  category        DocumentCategory? @relation(fields: [categoryId], references: [id])
  uploadedBy      User            @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  permissions     AccessPermission[]
  portalInstance  PortalInstance? @relation(fields: [portalInstanceId], references: [id], onDelete: Cascade)
}

model AccessPermission {
  id          String    @id @default(cuid())
  userId      String
  documentId  String
  canView     Boolean   @default(true)
  canDownload Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
}

model BrokerRequest {
  id          String    @id @default(cuid())
  userId      String
  propertyId  String
  message     String?
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model BrokerValuation {
  id          String    @id @default(cuid())
  userId      String
  propertyId  String
  amount      Decimal?  @db.Decimal(14, 2)
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model TenantProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  unitId                String?
  firstName             String
  lastName              String
  birthdate             DateTime?
  currentAddress        String?
  phone                 String?
  email                 String
  moveInDate            DateTime?
  moveOutDate           DateTime?
  isCurrent             Boolean   @default(true)
  leaseStartDate        DateTime?
  rentAmount            Decimal?  @db.Decimal(12, 2)
  garageRent            Decimal?  @db.Decimal(12, 2)
  serviceCharges        Decimal?  @db.Decimal(12, 2)
  deposit               Decimal?  @db.Decimal(12, 2)
  occupantCount         Int?
  bankAccount           String?
  rentDueDay            Int?
  landlordBankAccount   String?
  landlordBankName      String?
  roomDescription       String?
  sharedRooms           String?
  steppedRent           String?
  contractNotes         String?
  pets                  String?
  specialAgreements     String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit                  Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  contracts             LeaseContract[]
}

model ContractTemplate {
  id          String          @id @default(cuid())
  portalInstanceId String?
  name        String
  filename    String
  storagePath String
  mimeType    String
  size        Int
  createdAt   DateTime        @default(now())
  contracts   LeaseContract[]
  portalInstance PortalInstance? @relation(fields: [portalInstanceId], references: [id], onDelete: Cascade)
}

model LeaseContract {
  id              String            @id @default(cuid())
  unitId          String
  tenantProfileId String
  templateId      String?
  docxPath        String
  pdfPath         String?
  createdAt       DateTime          @default(now())
  unit            Unit              @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenantProfile   TenantProfile     @relation(fields: [tenantProfileId], references: [id], onDelete: Cascade)
  template        ContractTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id        String      @id @default(cuid())
  portalInstanceId String?
  userId    String?
  action    AuditAction
  entity    String?
  entityId  String?
  ipAddress String?
  detail    Json?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  portalInstance PortalInstance? @relation(fields: [portalInstanceId], references: [id], onDelete: Cascade)
}
